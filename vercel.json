{
  "buildCommand": "npm run build",
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/health",
      "destination": "https://yamaha-scan-tiketing-production.up.railway.app/health"
    },
    {
      "source": "/api/platform/:path*",
      "destination": "https://yamaha-scan-tiketing-production.up.railway.app/platform/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://yamaha-scan-tiketing-production.up.railway.app/api/:path*"
    },
    {
      "source": "/platform/:path*",
      "destination": "https://yamaha-scan-tiketing-production.up.railway.app/platform/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
