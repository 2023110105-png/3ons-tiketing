# ==========================================
# Twilio WhatsApp API Configuration
# Production-safe alternative to whatsapp-web.js
# ==========================================

# Provider Selection
# Options: 'whatsapp-web' (default), 'twilio'
WHATSAPP_PROVIDER=twilio

# Twilio Credentials (get from console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=+14155238886

# Rate Limiting (Twilio: max 1 msg/sec for WhatsApp)
RATE_LIMIT_MS=1000

# Webhook URL (for receiving messages)
# Set in Twilio Console > WhatsApp > Sandbox Settings
TWILIO_WEBHOOK_URL=https://your-domain.com/api/twilio/webhook

# ==========================================
# Optional: Fallback Configuration
# ==========================================
# If Twilio fails, fallback to whatsapp-web.js (not recommended)
ENABLE_FALLBACK=false

# ==========================================
# Legacy whatsapp-web.js (keep for reference)
# ==========================================
# WA_PROVIDER=local
# PORT=3001
