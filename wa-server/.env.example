PORT=3001
NODE_ENV=development

# Comma-separated allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5174

# Required for protected admin endpoints
WA_ADMIN_SECRET=replace-with-strong-secret

# Required for HMAC ticket signing (can differ from WA_ADMIN_SECRET)
TICKET_SIGNING_SECRET=replace-with-strong-signing-secret

# Optional SMTP for email ticket delivery
SMTP_SERVICE=gmail
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Persist WhatsApp session across redeploys (Railway: mount a volume and set this path)
# Example on Railway: mount volume at /data/wa-auth and set WA_AUTH_DATA_PATH=/data/wa-auth
# WA_AUTH_DATA_PATH=/data/wa-auth

# Optional runtime tuning
REQUEST_TIMEOUT_MS=30000
RATE_LIMIT_WINDOW_MS=10000
RATE_LIMIT_MAX=30
WA_PROTOCOL_TIMEOUT_MS=180000
WA_LAUNCH_TIMEOUT_MS=180000
