# Base API (WA server)
# Untuk dev lokal biasanya pakai proxy Vite, jadi bisa dikosongkan.
# Isi jika ingin pakai endpoint backend langsung.
VITE_API_BASE_URL=

# Optional for local backend deployment
PORT=3001

# Firebase mode
VITE_USE_FIREBASE=true
VITE_FIREBASE_AUTH_MODE=strict
VITE_FIREBASE_DATA_MODE=strict

# Firebase Web App config (WAJIB diisi dari Firebase Project Settings > General > Your apps)
VITE_FIREBASE_API_KEY=AIzaSyBesPBHh9fTpmMtAWnmZyxH9xqaixmsiuY
VITE_FIREBASE_AUTH_DOMAIN=ons-bot-webapps.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=ons-bot-webapps
VITE_FIREBASE_STORAGE_BUCKET=ons-bot-webapps.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=952086061904
VITE_FIREBASE_APP_ID=1:952086061904:web:fcfe7c8338109c45f70255

# Optional
VITE_FIREBASE_MEASUREMENT_ID=G-WCQSRDSY9S
