PORT=3002

# Comma-separated allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5174

# Firebase Admin credentials (required)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Owner API protection secret (required in production)
PLATFORM_ADMIN_SECRET=replace-with-strong-secret

# Local development only (never true in production)
API_DEV_BYPASS_AUTH=false

# Optional
REQUEST_TIMEOUT_MS=30000
RATE_LIMIT_WINDOW_MS=10000
RATE_LIMIT_MAX=40
