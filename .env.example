VITE_API_BASE_URL=https://bot-api.domain-anda.com

# Optional for local backend deployment
PORT=3001

# Firebase mode
VITE_USE_FIREBASE=true
VITE_FIREBASE_AUTH_MODE=strict
VITE_FIREBASE_DATA_MODE=strict

# Data backend selector: firebase | supabase
VITE_DATA_BACKEND=firebase

# Firebase Web App config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional
VITE_FIREBASE_MEASUREMENT_ID=G-WCQSRDSY9S

# Supabase (required only when VITE_DATA_BACKEND=supabase)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
